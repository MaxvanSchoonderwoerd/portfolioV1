---
import HorizontalCard from "./HorizontalCard.astro";
import { getLangFromUrl, useTranslations, localizePath } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { page } = Astro.props;
---

<div class="p-6 pt-10 max-w-[900px]">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">{t("projects.heading")} {"</>"}</div>
  </div>

  {
    page.data.length === 0 ? (
      <div class="bg-base-200 border-l-4 border-secondary w-full p-4 min-w-full">
        <p class="font-bold">{t("projects.empty.title")}</p>
        <p>{t("projects.empty.text")}</p>
      </div>
    ) : (
      <ul>
        {page.data.map(({ slug, entry }) => (
          <>
            <HorizontalCard
              title={entry.data.title}
              img={entry.data.heroImage}
              desc={entry.data.description}
              stack={entry.data.stack}
              url={localizePath("/projects/" + slug, lang)}
              target="_self"
              badge={entry.data.badge}
            />
            <div class="divider my-0" />
          </>
        ))}
      </ul>
    )
  }

  <div class="flex justify-between">
    {
      page.url.prev ? (
        <a href={page.url.prev} class="btn btn-ghost my-10 mx-5">
          {" "}
          <svg
            class="h-6 w-6 fill-current md:h-8 md:w-8"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
          >
            <path d="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z" />
          </svg>{" "}
          {t("projects.newer")}
        </a>
      ) : (
        <div />
      )
    }
    {
      page.url.next ? (
        <a href={page.url.next} class="btn btn-ghost my-10 mx-5">
          {t("projects.older")}{" "}
          <svg
            class="h-6 w-6 fill-current md:h-8 md:w-8"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
          >
            {" "}
            <path d="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" />
          </svg>
        </a>
      ) : (
        <div />
      )
    }
  </div>
</div>
