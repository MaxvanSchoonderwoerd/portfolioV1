---
import { render } from "astro:content";
import type { ProjectSchema } from "../../content.config";
import PostLayout from "../../layouts/PostLayout.astro";
import { getProjects } from "../../i18n/projects";

export async function getStaticPaths() {
  const projects = await getProjects("nl");
  return projects.map(({ slug, entry }) => ({
    params: { slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const post: ProjectSchema = entry.data;
const { Content } = await render(entry);
---

<PostLayout
  title={post.title}
  description={post.description}
  stack={post.stack}
  pubDate={post.pubDate}
  heroImage={post.heroImage}
  updatedDate={post.updatedDate}
  badge={post.badge}
  screenshotsMobile={post.screenshotsMobile}
  screenshotsDesktop={post.screenshotsDesktop}
>
  <Content />
</PostLayout>
