---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ProjectsList from "../../../components/ProjectsList.astro";
import { getProjects } from "../../../i18n/projects";

export async function getStaticPaths({ paginate }) {
  const projects = await getProjects("en");
  return paginate(projects, { pageSize: 10 });
}

const { page } = Astro.props;
---

<BaseLayout
  title="Max van Schoonderwoerd | Projects"
  sideBarActiveItemID="projects"
>
  <ProjectsList page={page} />
</BaseLayout>
