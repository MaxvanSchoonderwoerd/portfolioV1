---
import type { ProjectSchema } from "../content.config";
import BaseLayout from "./BaseLayout.astro";
import dayjs from "dayjs";
import "dayjs/locale/nl"; // import Dutch locale

import localizedFormat from "dayjs/plugin/localizedFormat";
import { getLangFromUrl, useTranslations, localizePath } from "../i18n/utils";

export interface Props extends ProjectSchema {}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const dateLocale = lang === "nl" ? "nl" : "en";

const {
  title,
  description,
  stack,
  pubDate,
  updatedDate,
  heroImage,
  badge,
  screenshotsMobile,
  screenshotsDesktop,
} = Astro.props;

dayjs.extend(localizedFormat);

const displayDate = dayjs(pubDate).locale(dateLocale).format("D MMMM YYYY");
const displayUpdatedDate = updatedDate
  ? dayjs(updatedDate).locale(dateLocale).format("ll")
  : null;
---

<BaseLayout title={title} description={description} image={heroImage}>
  <main class="flex justify-center items-center flex-col">
    {
      heroImage && (
        <img
          src={heroImage}
          width={1920}
          height={1080}
          alt={title}
          class="w-full mb-6"
        />
      )
    }
    <div class="p-6 pt-10 max-w-[900px]">
      <a href={localizePath("/projects", lang)} class="btn btn-md w-24 mb-4"
        >{t("projects.back")}</a
      >
      <article class="prose prose-lg max-w-[750px]">
        <h1 class="title my-2 text-4xl font-bold">{title}</h1>
        {pubDate && <time>{displayDate}</time>}
        <br />
        {badge && <div class="badge badge-secondary my-1">{badge}</div>}
        {
          displayUpdatedDate && (
            <div>
              {t("post.lastUpdated")} <time>{displayUpdatedDate}</time>
            </div>
          )
        }

        <div class="divider my-2"></div>
        <slot />

        <div class="my-6">
          <h2 class="text-xl font-semibold">{t("post.techStack")}</h2>
          <p>{stack}</p>
        </div>
      </article>

      <>
        {
          (screenshotsMobile || screenshotsDesktop) && (
            <>
              <div class="divider my-8" />
              <h2 class="text-2xl font-bold mb-8">{t("post.screenshots")}</h2>
            </>
          )
        }
        {
          screenshotsMobile && (
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-16">
              {screenshotsMobile.map((path, i) => (
                <img
                  src={path}
                  alt={`Mobile screenshot ${i + 1} of ${title}`}
                />
              ))}
            </div>
          )
        }

        {
          screenshotsDesktop && (
            <div class="grid grid-cols-1 sm:grid-cols-1 gap-32 mt-8">
              {screenshotsDesktop.map((path, i) => (
                <img
                  src={path}
                  alt={`Desktop screenshot ${i + 1} of ${title}`}
                />
              ))}
            </div>
          )
        }
      </>
    </div>
  </main>
</BaseLayout>
