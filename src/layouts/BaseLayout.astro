---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SideBar from "../components/SideBar.astro";

import { SITE_TITLE, SITE_DESCRIPTION } from "../config";
import { getLangFromUrl } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);

const {
  image,
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  includeSidebar = true,
  sideBarActiveItemID,
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <script>
      (function () {
        try {
          const mq = window.matchMedia("(prefers-color-scheme: dark)");
          const apply = (isDark: boolean) =>
            document.documentElement.setAttribute(
              "data-theme",
              isDark ? "dark" : "light"
            );
          apply(mq.matches);
          // React to OS theme changes while the page is open.
          mq.addEventListener("change", (e) => apply(e.matches));
        } catch (e) {
          console.warn("Could not set theme from system preference:", e);
        }
      })();
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Max van Schoonderwoerd",
        "url": "https://www.maxvanschoonderwoerd.nl",
        "jobTitle": "Webdeveloper en designer",
        "alumniOf": "Hogeschool Rotterdam",
        "sameAs": [
          "https://www.linkedin.com/in/maxvanschoonderwoerd",
          "https://github.com/maxvanschoonderwoerd"
        ]
      }
    </script>
    <BaseHead title={title} description={description} image={image} />
  </head>
  <body>
    <div class="bg-base-100 drawer lg:drawer-open">
      <input id="my-drawer" type="checkbox" class="drawer-toggle" />
      <div class="drawer-content bg-base-100">
        <Header title={SITE_TITLE} />

        <div class="md:flex md:justify-center">
          <main>
            <slot />
          </main>
        </div>
        <Footer />
      </div>
      {includeSidebar && <SideBar sideBarActiveItemID={sideBarActiveItemID} />}
    </div>
  </body>
</html>
